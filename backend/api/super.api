service Super {
	// 获取群组列表
	@handler getGroups
	get /api/community/groups (GetGroupsReq) returns (GetGroupsResp)

	// 获取群详情
	@handler getGroup
	get /api/community/groups/:group_id (GetGroupReq) returns (GetGroupResp)

	// 创建群组
	@handler createGroup
	post /api/community/groups (CreateGroupReq) returns (CreateGroupResp)

	// 更新群组信息
	@handler updateGroup
	put /api/community/groups/:group_id (UpdateGroupReq) returns (UpdateGroupResp)

	// 删除群组
	@handler deleteGroup
	delete /api/community/groups/:group_id (DeleteGroupReq) returns (BaseResp)

	// 加入群组
	@handler joinGroup
	post /api/community/groups/:group_id/join (JoinGroupReq) returns (BaseResp)

	// 退出群组
	@handler leaveGroup
	post /api/community/groups/:group_id/leave (LeaveGroupReq) returns (BaseResp)

	// 获取群组成员列表
	@handler getGroupMembers
	get /api/community/groups/:group_id/members (GetGroupMembersReq) returns (GetGroupMembersResp)

	// 获取用户加入的群组
	@handler getUserGroups
	get /api/user/:user_id/community/groups (GetUserGroupsReq) returns (GetUserGroupsResp)

	// 发布群组帖子
	@handler createGroupPost
	post /api/community/groups/:group_id/posts (CreateGroupPostReq) returns (CreateGroupPostResp)

	// 获取群组帖子列表
	@handler getGroupPosts
	get /api/community/groups/:group_id/posts (GetGroupPostsReq) returns (GetGroupPostsResp)
}

// WebSocket 服务组 (不使用JWT middleware，在handler内部验证token)
@server (
	group: chat
)
service Super {
	@doc "WebSocket聊天服务"
	@handler ChatWs
	get /ws/chat

	@doc "WebSocket远程控制服务"
	@handler RemoteWs
	get /ws/remote

	@doc "WebSocket在线状态服务"
	@handler PresenceWs
	get /ws/presence

	@doc "WebSocket大世界同步（房间广播，JSON）"
	@handler WorldWs
	get /ws/world
}

