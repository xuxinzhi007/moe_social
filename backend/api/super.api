// 礼物相关API服务
@server (
	group: gift
)
service Super {
	// 获取礼物列表
	@handler getGifts
	get /api/gifts (GetGiftsReq) returns (GetGiftsResp)

	// 获取礼物详情
	@handler getGift
	get /api/gifts/:gift_id (GetGiftReq) returns (GetGiftResp)

	// 发送礼物
	@handler sendGift
	post /api/user/:user_id/gifts/send (SendGiftReq) returns (SendGiftResp)

	// 获取用户礼物记录
	@handler getGiftRecords
	get /api/user/:user_id/gifts/records (GetGiftRecordsReq) returns (GetGiftRecordsResp)

	// 礼物购买订单（余额购买进背包）
